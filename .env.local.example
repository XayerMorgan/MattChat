# Copy to .env.local and adjust.
#   Mac/Linux:  cp .env.local.example .env.local
#   Windows:    copy .env.local.example .env.local
#
# Two deployment patterns:
#   A) LOCAL CLIENT  — MattChat on each laptop; LM Studio on Mac Studio (shared).
#   B) SERVER HOST   — MattChat on the Mac Studio; everyone opens http://studio:3010
#
# See SETUP.md and docs for MATTCHAT_HOST_MODE.

# --- Host mode ---
# local  = single-user laptop (default)
# server = multi-user host (LAN), capacity enforced
MATTCHAT_HOST_MODE=local
MATTCHAT_MAX_CONNECTIONS=100
MATTCHAT_SERVER_NAME=MattChat
# Optional admin token for GET /api/admin/status in server mode
# MATTCHAT_ADMIN_TOKEN=change-me-long-secret

# --- Shared LM Studio (Mac Studio / lab host) ---
LM_STUDIO_BASE_URL=http://vpit-llm2.jck.txstate.edu:1234/v1
LM_STUDIO_API_KEY=

# --- If you run LM Studio on THIS machine instead ---
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# --- Optional cloud providers (leave blank if unused) ---
XAI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
