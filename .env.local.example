# Optional — env vars override keys saved in the API keys UI
# (config/api-keys.json). Prefer the in-app API keys panel for local use.

XAI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# LM Studio (usually no key required)
LM_STUDIO_API_KEY=
# Local:
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# Campus remote example:
# LM_STUDIO_BASE_URL=http://vpit-llm2.jck.txstate.edu:1234/v1
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
